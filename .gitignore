# Obsidian vault metadata (regeneratable)
.obsidian/
.trash/

# Opencode runtime
.opencode/
.logs/

# Engine runtime state (regenerated on every run)
.raw-manifest.json
.content-brief.json
.wiki-state
.wiki-state.lock
.checkpoints/
logs/
content/queue/
content/posted/
content/sessions/
content/rejected/

# OS junk
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Build/cache
*.log
__pycache__/
*.pyc

# Banner preview HTML (regenerated by `banner_tool preview --open`)
assets/banners/.preview/

# Dependencies
node_modules/

# PII / source-of-truth files that should never be in the repo
# (the user's resume, env, credentials)
.env
.env.local
*.pdf
!templates/*.pdf
!raw/*.pdf
