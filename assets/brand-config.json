{
  "brand_name": "Your Brand",
  "tagline": "Your tagline here",
  "colors": { "primary": "#000000", "secondary": "#666666", "accent": "#ff6a00" },
  "fonts": {
    "heading": "Inter",
    "body": "Inter",
    "google_fonts": "https://fonts.googleapis.com/css2?family=Inter:wght@600;700;900&family=Merriweather:wght@300;400;700&display=swap",
    "use_google_fonts": true
  },
  "logo_path": "",
  "voice_keywords": [],
  "target_platforms": ["x", "linkedin", "blog"],
  "content_focus": "",
  "brand": {
    "name": "Your Brand",
    "handle": "@yourhandle",
    "primary_bg": "#f5f5f5",
    "accent": "#ff6a00",
    "text_dark": "#202020",
    "text_mid": "#5a5959",
    "background": {
      "type": "solid",
      "value": "#f5f5f5"
    }
  },
  "banner": {
    "template": "default",
    "icon_collection": {
      "url": "https://github.com/la-moore/scarlab-icons",
      "source": "github"
    },
    "render": {
      "device_scale_factor": 2,
      "chrome_path": null
    },
    "dimensions": {
      "width": 1200,
      "height": 630
    },
    "tokens": {
      "bg": "#f5f5f5",
      "font_heading": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
      "font_subtitle": "'Merriweather', Georgia, 'Times New Roman', serif",
      "text_title_color": "#ff6a00",
      "text_title_size": "96px",
      "text_title_size_min": 56,
      "text_title_weight": 900,
      "text_title_shadow": "2px 2px 0 #ffffff",
      "text_title_lh": 1.1,
      "text_title_letterspacing": "-0.03em",
      "text_subtitle_color": "#202020",
      "text_subtitle_size": "32px",
      "text_subtitle_weight": 400,
      "text_subtitle_lh": 1.4,
      "text_subtitle_letterspacing": "0.02em",
      "text_subtitle_highlight": "rgba(255, 228, 77, 0.3)",
      "text_subtitle_max_chars": 80,
      "text_handle": "#5a5959",
      "text_handle_size": "22px",
      "text_handle_weight": 400,
      "text_handle_letterspacing": "0.04em",
      "text_handle_align": "center",
      "text_handle_bottom": "32px",
      "icon_color": "#444444",
      "icon_opacity": 0.15,
      "icon_size": "780px",
      "icon_rotate": "30deg",
      "icon_position_x": "right",
      "icon_position_y": "center",
      "icon_offset_x": "40px",
      "icon_offset_y": "-50%",
      "content_padding": "60px 80px 80px",
      "content_width": "85%",
      "text_align": "left"
    },
    "icon_mapping": {
      "default": "arrow-up-right",
      "rules": [
        { "patterns": ["ai", "agent", "automation", "machine", "llm", "gpt", "model"], "icon": "sparkles" },
        { "patterns": ["open source", "github", "repo"], "icon": "git-pull-request" },
        { "patterns": ["system", "process", "engine", "workflow", "architecture", "infrastructure", "stack", "framework", "pipeline"], "icon": "cog" },
        { "patterns": ["growth", "scale", "business", "revenue", "metrics", "kpi", "analytics", "data", "trend"], "icon": "trending-up" },
        { "patterns": ["code", "build", "develop", "ship", "deploy", "api", "script", "dev"], "icon": "code" },
        { "patterns": ["terminal", "cli", "command", "console"], "icon": "terminal" },
        { "patterns": ["strategy", "plan", "positioning", "offer", "method", "pillar"], "icon": "crosshair" },
        { "patterns": ["idea", "learn", "knowledge", "note", "insight", "lesson", "concept", "think"], "icon": "bulb" },
        { "patterns": ["goal", "target", "focus", "priority", "mission", "objective", "outcome"], "icon": "crosshair" },
        { "patterns": ["launch", "start", "mvp", "product", "release"], "icon": "award" },
        { "patterns": ["layer", "level", "tier", "depth"], "icon": "layers" },
        { "patterns": ["publish", "content", "post", "draft", "blog", "tweet", "schedule", "queue"], "icon": "mail" },
        { "patterns": ["write", "story", "copy", "headline", "hook"], "icon": "feather" },
        { "patterns": ["identity", "creator", "builder", "founder", "technical", "engineer"], "icon": "location" },
        { "patterns": ["stop", "pause", "limit", "bottleneck", "barrier", "block", "bounce", "ceiling", "trap", "enough", "alert", "warning", "critical", "urgent"], "icon": "ban" },
        { "patterns": ["scan", "scanning", "qrcode", "qr code", "decode", "extract", "extracting"], "icon": "qrcode" }
      ]
    }
  },
  "icons": {
    "default": "arrow-up-right",
    "source": "inline",
    "registry": {
      "arrow-up-right": { "svg_path": "icons/arrow-up-right.svg", "fallback_svg": "" },
      "award": { "svg_path": "icons/award.svg", "fallback_svg": "" },
      "ban": { "svg_path": "icons/ban.svg", "fallback_svg": "" },
      "bulb": { "svg_path": "icons/bulb.svg", "fallback_svg": "" },
      "code": { "svg_path": "icons/code.svg", "fallback_svg": "" },
      "cog": { "svg_path": "icons/cog.svg", "fallback_svg": "" },
      "crosshair": { "svg_path": "icons/crosshair.svg", "fallback_svg": "" },
      "feather": { "svg_path": "icons/feather.svg", "fallback_svg": "" },
      "git-pull-request": { "svg_path": "icons/git-pull-request.svg", "fallback_svg": "" },
      "layers": { "svg_path": "icons/layers.svg", "fallback_svg": "" },
      "location": { "svg_path": "icons/location.svg", "fallback_svg": "" },
      "mail": { "svg_path": "icons/mail.svg", "fallback_svg": "" },
      "qrcode": { "svg_path": "icons/qrcode.svg", "fallback_svg": "" },
      "sparkles": { "svg_path": "icons/sparkles.svg", "fallback_svg": "" },
      "terminal": { "svg_path": "icons/terminal.svg", "fallback_svg": "" },
      "trending-up": { "svg_path": "icons/trending-up.svg", "fallback_svg": "" }
    },
    "style": {
      "opacity": 0.15,
      "color": "#444444",
      "size_percent": 100,
      "rotate_deg": 30
    }
  }
}
