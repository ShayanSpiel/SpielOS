{
  "brand_name": "Your Brand",
  "tagline": "Your tagline here",
  "colors": { "primary": "#000000", "secondary": "#666666", "accent": "#ff6a00" },
  "fonts": { "heading": "Inter", "body": "Inter" },
  "logo_path": "",
  "voice_keywords": [],
  "target_platforms": ["x", "linkedin", "blog"],
  "content_focus": "",
  "brand": {
    "name": "Your Brand",
    "handle": "@yourhandle",
    "primary_bg": "#f5f5f5",
    "accent": "#ff6a00",
    "text_dark": "#202020",
    "text_mid": "#5a5959",
    "background": {
      "type": "solid",
      "value": "#f5f5f5"
    }
  },
  "banners": {
    "default": {
      "name": "OG Banner",
      "description": "1200x630 OG card. Left-aligned content, icon watermark right-center.",
      "dimensions": { "width": 1200, "height": 630 },
      "title": {
        "max_words": 8,
        "font_size_px": 96,
        "font_size_min_px": 56,
        "color": "#ff6a00",
        "weight": 900,
        "letter_spacing": "-0.03em",
        "line_height": 1.1
      },
      "subtitle": {
        "font_size_px": 32,
        "color": "#202020",
        "weight": 400,
        "letter_spacing": "0.02em",
        "line_height": 1.4,
        "highlight": "transparent",
        "max_chars": 80
      },
      "handle": {
        "font_size_px": 22,
        "color": "#5a5959",
        "weight": 400,
        "letter_spacing": "0.04em",
        "alignment": "center",
        "position_bottom_px": 32
      },
      "layout": {
        "content_alignment": "left",
        "content_padding": "60px 80px 80px",
        "icon_position_x": "right",
        "icon_position_y": "center",
        "icon_offset_x": "-10%",
        "icon_offset_y": "-50%"
      }
    }
  },
  "render": {
    "device_scale_factor": 2
  },
  "icons": {
    "default": "arrow-up-right-square",
    "source": "inline",
    "registry": {
      "arrow-up-right-square": {
        "svg_path": "icons/arrow-up-right-square.svg",
        "web_url": "https://www.svgrepo.com/svg/507931/arrow-up-right-square",
        "fallback_svg": ""
      },
      "gears": { "svg_path": "icons/gears.svg", "fallback_svg": "" },
      "code": { "svg_path": "icons/code.svg", "fallback_svg": "" },
      "compass": { "svg_path": "icons/compass.svg", "fallback_svg": "" },
      "archery-target": { "svg_path": "icons/archery-target.svg", "fallback_svg": "" },
      "feather": { "svg_path": "icons/feather.svg", "fallback_svg": "" },
      "layers": { "svg_path": "icons/layers.svg", "fallback_svg": "" },
      "lightbulb": { "svg_path": "icons/lightbulb.svg", "fallback_svg": "" },
      "publish": { "svg_path": "icons/publish.svg", "fallback_svg": "" },
      "rocket": { "svg_path": "icons/rocket.svg", "fallback_svg": "" },
      "sparkles": { "svg_path": "icons/sparkles.svg", "fallback_svg": "" },
      "target": { "svg_path": "icons/target.svg", "fallback_svg": "" },
      "terminal": { "svg_path": "icons/terminal.svg", "fallback_svg": "" },
      "trending-up": { "svg_path": "icons/trending-up.svg", "fallback_svg": "" },
      "stop-circle": { "svg_path": "icons/stop-circle.svg", "fallback_svg": "" },
      "alert-circle": { "svg_path": "icons/alert-circle.svg", "fallback_svg": "" },
      "alert-square": { "svg_path": "icons/alert-square.svg", "fallback_svg": "" },
      "github": { "svg_path": "icons/github.svg", "fallback_svg": "", "opacity": 0.20, "color": "#444444", "size_percent": 100, "rotate_deg": 30 }
    },
    "web_search": {
      "base_url": "https://www.svgrepo.com/collections/",
      "default_collection": "arrows",
      "instructions": "Search SVG Repo (https://www.svgrepo.com) for best SVG aligned with content context. Filter by: monocolor, stroke-based, 24x24 viewBox ideal. Prefer simple geometric icons."
    },
    "mapping": [
      { "patterns": ["ai", "agent", "automation", "machine", "llm", "gpt", "model"], "icon": "sparkles" },
      { "patterns": ["open source", "github", "repo"], "icon": "github" },
      { "patterns": ["system", "process", "engine", "workflow", "architecture", "infrastructure", "stack", "framework", "pipeline"], "icon": "gears" },
      { "patterns": ["growth", "scale", "business", "revenue", "metrics", "kpi", "analytics", "data", "trend"], "icon": "trending-up" },
      { "patterns": ["code", "build", "develop", "ship", "deploy", "api", "script", "dev"], "icon": "code" },
      { "patterns": ["terminal", "cli", "command", "console"], "icon": "terminal" },
      { "patterns": ["strategy", "plan", "positioning", "offer", "method", "pillar"], "icon": "target" },
      { "patterns": ["idea", "learn", "knowledge", "note", "insight", "lesson", "concept", "think"], "icon": "lightbulb" },
      { "patterns": ["goal", "target", "focus", "priority", "mission", "objective", "outcome"], "icon": "target" },
      { "patterns": ["launch", "start", "mvp", "product", "release"], "icon": "rocket" },
      { "patterns": ["layer", "level", "tier", "depth"], "icon": "layers" },
      { "patterns": ["publish", "content", "post", "draft", "blog", "tweet", "schedule", "queue"], "icon": "publish" },
      { "patterns": ["write", "story", "copy", "headline", "hook"], "icon": "feather" },
      { "patterns": ["identity", "creator", "builder", "founder", "technical", "engineer"], "icon": "compass" },
      { "patterns": ["stop", "pause", "limit", "bottleneck", "barrier", "block", "bounce", "ceiling", "trap", "enough", "alert", "warning", "critical", "urgent"], "icon": "alert-square" }
    ],
    "style": {
      "opacity": 0.25,
      "color": "#444444",
      "size_percent": 105,
      "rotate_deg": 20
    }
  }
}
