#!/usr/bin/env bash
# bin/spiel — Single entrypoint for SpielOS.
#
# Resolves the vault root, then execs the requested command.
# Works from ANY working directory, in ANY project, in ANY IDE.
#
# VAULT_DIR resolution order (first match wins):
#   0. $VAULT_DIR                  (env override — most explicit)
#   1. ~/.config/spielos/config     (global config set by installer — primary)
#   2. <cwd>/.spiel-vault          (project-local override file; may set VAULT_DIR=…)
#   3. <cwd>/team/director.md      (any parent with the vault marker)
#   4. <this-shim>/..              (only when this shim lives at <vault>/bin/spiel)
#
# Usage (from anywhere):
#   spiel --version
#   spiel --where
#   spiel /post
#   spiel /post "Just shipped v2"
#   spiel /post @file:./notes.md
#   spiel status
#   spiel status --json
#
# Install (idempotent, safe to re-run):
#   install -m 0755 bin/spiel ~/.local/bin/spiel
#
# This file is identical wherever it lives. Keep both copies in sync.

set -euo pipefail

VERSION="1.0.0"
SHIM_PATH="$HOME/.local/bin/spiel"

# ── Help / version (no vault needed) ──────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'USAGE'
spiel — SpielOS orchestrator shim.

USAGE:
  spiel [--version] [--help] [--where] <command> [args...]

COMMANDS:
  /post [topic|@file:]
                         Run the content pipeline end-to-end
  /post                  (no args = use current IDE conversation if it has real source)
  status                 Show current pipeline state
  status --json          Same, JSON output
  set-vault <path>       Change which vault spiel resolves to (writes global config)
  init                   Re-run the install wizard (rewrites .env, strategy, brand)
  update                 Pull latest tools/install + sync to IDEs
                         (preserves team/, skills/, strategy/, content/, .env, brand.*)
  sync                   Regenerate IDE adapter files
  test                   Run the test suite
  config                 Print resolved vault + tool paths
  help                   Show this help

VAULT_DIR is resolved (first match wins):
  0. ~/.config/spielos/config           (global config set by installer)
  1. $VAULT_DIR env var
  2. walk up from cwd for .spiel-vault  (a file containing VAULT_DIR=/abs/path)
  3. walk up from cwd for team/director.md (any parent with the vault marker)
  4. <shim>/..                          (when shim is bundled at <vault>/bin/spiel)

The vault is the directory you install into (your project root).
The shim is path-independent: invoke it from anywhere inside the vault.
USAGE
  exit 0
fi

# ── Vault resolution ─────────────────────────────────────────────────

SPIELOS_GLOBAL_CONFIG="$HOME/.config/spielos/config"

# A candidate is only accepted if it points to a directory that contains
# team/director.md. Each option below is tried in order; an invalid env var,
# stale symlink, or missing path falls through to the next option.
_resolve_vault() {
  local candidate=""

  # 0. Inline env var — most explicit override.
  if [[ -z "$candidate" && -n "${VAULT_DIR:-}" ]]; then
    if [[ -d "${VAULT_DIR}/team" && -f "${VAULT_DIR}/team/director.md" ]]; then
      candidate="${VAULT_DIR}"
    fi
  fi

  # 1. Global config (~/.config/spielos/config) — set by installer, not cwd-dependent
  if [[ -z "$candidate" && -f "$SPIELOS_GLOBAL_CONFIG" ]]; then
    local override
    override=$(grep -E '^VAULT_DIR=' "$SPIELOS_GLOBAL_CONFIG" 2>/dev/null | head -1 | cut -d= -f2- || true)
    override="${override%\"}"; override="${override#\"}"
    override="${override%\'}"; override="${override#\'}"
    if [[ -n "$override" && -d "$override/team" && -f "$override/team/director.md" ]]; then
      candidate="$override"
    fi
  fi

  # 2. Walk up from cwd for .spiel-vault
  if [[ -z "$candidate" ]]; then
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
      if [[ -f "$dir/.spiel-vault" ]]; then
        local override
        override=$(grep -E '^VAULT_DIR=' "$dir/.spiel-vault" 2>/dev/null | head -1 | cut -d= -f2- || true)
        override="${override%\"}"; override="${override#\"}"
        override="${override%\'}"; override="${override#\'}"
        if [[ -n "$override" && -d "$override/team" && -f "$override/team/director.md" ]]; then
          candidate="$override"
          break
        fi
      fi
      dir=$(dirname "$dir")
    done
  fi

  # 3. Walk up from cwd for team/director.md
  if [[ -z "$candidate" ]]; then
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
      if [[ -d "$dir/team" && -f "$dir/team/director.md" ]]; then
        candidate="$dir"
        break
      fi
      dir=$(dirname "$dir")
    done
  fi

  # 4. Shim bundled in vault (this file is at <vault>/bin/spiel).
  if [[ -z "$candidate" ]]; then
    local shim_path="${BASH_SOURCE[0]:-$0}"
    # If shim is a symlink, follow it.
    if [[ -L "$shim_path" ]]; then
      local shim_target
      shim_target=$(readlink "$shim_path" 2>/dev/null || true)
      if [[ -n "$shim_target" ]]; then
        local shim_dir
        shim_dir=$(cd "$(dirname "$shim_path")" && pwd)
        local resolved
        if [[ "$shim_target" = /* ]]; then
          resolved="$shim_target"
        else
          resolved="$shim_dir/$shim_target"
        fi
        shim_path="$resolved"
      fi
    fi
    local shim_dir
    shim_dir=$(cd "$(dirname "$shim_path")" && pwd)
    if [[ "$shim_dir" == */bin ]] && [[ -f "$shim_dir/../team/director.md" ]]; then
      candidate=$(cd "$shim_dir/.." && pwd)
    fi
  fi

  # Validate
  if [[ -z "$candidate" || ! -d "$candidate/team" || ! -f "$candidate/team/director.md" ]]; then
    echo "ERROR: spiel could not locate the SpielOS vault." >&2
    echo "" >&2
    echo "  Tried (in order):" >&2
    echo "    0. \$VAULT_DIR env var:           ${VAULT_DIR:-<unset>}" >&2
    echo "    1. ~/.config/spielos/config:     $SPIELOS_GLOBAL_CONFIG" >&2
    local _sv=""
    local d="$PWD"
    while [[ "$d" != "/" ]]; do
      if [[ -f "$d/.spiel-vault" ]]; then _sv="$d/.spiel-vault"; break; fi
      d=$(dirname "$d")
    done
    if [[ -n "$_sv" ]]; then
      echo "    2. <walk up> .spiel-vault:         $_sv" >&2
    else
      echo "    2. <walk up> .spiel-vault:         <not found>" >&2
    fi
    local _tm=""
    d="$PWD"
    while [[ "$d" != "/" ]]; do
      if [[ -f "$d/team/director.md" ]]; then _tm="$d/team/director.md"; break; fi
      d=$(dirname "$d")
    done
    if [[ -n "$_tm" ]]; then
      echo "    3. <walk up> team/director.md:     $_tm (invalid)" >&2
    else
      echo "    3. <walk up> team/director.md:     <not found>" >&2
    fi
    local sd
    sd=$(cd "$(dirname "$0")" && pwd)
    if [[ -f "$sd/../team/director.md" ]]; then
      echo "    4. <shim>/..:                    $sd/.." >&2
    else
      echo "    4. <shim>/..:                    $sd/.. (not a bundle)" >&2
    fi
    echo "" >&2
    echo "  Fix: re-run the installer:" >&2
    echo "    curl -fsSL https://raw.githubusercontent.com/ShayanSpiel/Spiel-OS/main/install/install.sh | bash" >&2
    return 1
  fi

  (cd "$candidate" && pwd)
}

VAULT=$(_resolve_vault) || exit 1

# ── Tarball overlay (fallback for `update` when git pull fails) ────────

# Directories and files that update must NEVER overwrite (user data).
# These match what install.sh preserves during re-install.
_SPielos_SKIP_DIRS="team skills strategy content archive"
_SPielos_SKIP_FILES=".env system/brand.md system/brand.json"

_update_via_tarball() {
  SPIELOS_REPO="${SPIELOS_REPO:-ShayanSpiel/Spiel-OS}"
  local tarball="${TARBALL_URL:-https://github.com/$SPIELOS_REPO/archive/refs/heads/main.tar.gz}"
  local tmpdir
  tmpdir=$(mktemp -d) || { echo "  ⚠ mktemp failed" >&2; return 1; }

  _spiel_cleanup_tmp() { rm -rf "$tmpdir"; }
  trap _spiel_cleanup_tmp EXIT

  if ! curl -fsSL "$tarball" | tar -xz -C "$tmpdir" --strip-components=1 2>/dev/null; then
    echo "  ⚠ tarball download failed" >&2
    return 1
  fi

  # Overlay files from $tmpdir onto $VAULT, skipping user data dirs/files.
  # Reports each changed file individually.
  (cd "$VAULT" && python3 - <<PYEOF
import os, shutil, hashlib

def file_hash(path):
    h = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                h.update(chunk)
        return h.hexdigest()
    except OSError:
        return None

src = "$tmpdir"
dst = "$VAULT"
skip_dirs  = set("${_SPielos_SKIP_DIRS}".split())
skip_files = set("${_SPielos_SKIP_FILES}".split())
updated = []
added = []
skipped = 0

for root, dirs, files in os.walk(src):
    rel = os.path.relpath(root, src)
    parts = rel.split(os.sep) if rel != "." else []
    if any(p in skip_dirs for p in parts):
        continue
    for f in files:
        rel_file = os.path.relpath(os.path.join(root, f), src)
        if rel_file in skip_files:
            continue
        sp = os.path.join(root, f)
        dp = os.path.join(dst, rel_file)
        new_hash = file_hash(sp)
        old_hash = file_hash(dp)
        if new_hash == old_hash:
            skipped += 1
            continue
        os.makedirs(os.path.dirname(dp), exist_ok=True)
        shutil.copy2(sp, dp)
        if old_hash is None:
            added.append(rel_file)
        else:
            updated.append(rel_file)

if updated:
    print(f"  Updated ({len(updated)}):")
    for f in sorted(updated):
        print(f"    ~ {f}")
if added:
    print(f"  Added ({len(added)}):")
    for f in sorted(added):
        print(f"    + {f}")
if not updated and not added:
    print("  Already up to date.")
else:
    print(f"\n  {len(updated)} updated, {len(added)} added, {skipped} unchanged (user data preserved)")
PYEOF
)

  trap - EXIT
  rm -rf "$tmpdir"
}

# ── Rewrite vault pointer files (always, on update / install) ────────

_rewrite_vault_pointers() {
  # Safety: never write a temp-directory path to persistent config.
  # A tempdir leak would make spiel unresolvable on next invocation.
  case "$VAULT" in
    /tmp/*|/private/var/folders/*)
      echo "  ⚠ VAULT ($VAULT) looks like a temp directory — refusing to write" >&2
      return 1
      ;;
  esac
  if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/director.md" ]]; then
    echo "  ⚠ VAULT ($VAULT) is not a valid vault (no team/director.md) - refusing to write" >&2
    return 1
  fi

  printf 'VAULT_DIR=%s\n' "$VAULT" > "$VAULT/.spiel-vault"

  # Global config — merge VAULT_DIR with existing SOURCE_DIR
  mkdir -p "$HOME/.config/spielos"
  existing_source=$(grep -E '^SOURCE_DIR=' "$HOME/.config/spielos/config" 2>/dev/null | head -1 || true)
  printf 'VAULT_DIR=%s\n' "$VAULT" > "$HOME/.config/spielos/config"
  [[ -n "$existing_source" ]] && printf '%s\n' "$existing_source" >> "$HOME/.config/spielos/config"

  # Re-copy shim so next invocation uses the latest vault resolution logic
  if [[ -f "$VAULT/bin/spiel" ]]; then
    mkdir -p "$(dirname "$SHIM_PATH")"
    cp "$VAULT/bin/spiel" "$SHIM_PATH"
    chmod 0755 "$SHIM_PATH"
  fi

  if [[ -f "$VAULT/.env" ]]; then
    if grep -q '^VAULT_DIR=' "$VAULT/.env" 2>/dev/null; then
      sed -i '' "s|^VAULT_DIR=.*|VAULT_DIR=$VAULT|" "$VAULT/.env"
    else
      printf '\nVAULT_DIR=%s\n' "$VAULT" >> "$VAULT/.env"
    fi
    echo "  ✓ VAULT_DIR → $VAULT (global config + .env + .spiel-vault + shim)"
  else
    echo "  ✓ VAULT_DIR → $VAULT (global config + .spiel-vault + shim)"
  fi
}

# ── Version / where (vault already resolved) ─────────────────────────

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  echo "spiel $VERSION"
  echo "vault: $VAULT"
  exit 0
fi

if [[ "${1:-}" == "--where" ]]; then
  echo "$VAULT"
  exit 0
fi

# ── Dispatch ─────────────────────────────────────────────────────────

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is not on PATH. Install Python 3 and retry." >&2
  exit 127
fi

export VAULT_DIR="$VAULT"
cd "$VAULT"

# /post is run by the IDE's Director subagent. The CLI shim provides status / init / sync / test / config.

case "${1:-}" in
  status)
    if [[ "${2:-}" == "--json" ]]; then
      current="$VAULT/content/current.md"
      if [[ -f "$current" ]]; then
        echo "{ \"current\": \"$current\", \"state\": \"active\" }"
      else
        echo "{ \"current\": null, \"state\": \"idle\" }"
      fi
    else
      echo "SpielOS vault: $VAULT"
      current="$VAULT/content/current.md"
      if [[ -f "$current" ]]; then
        echo "Current run: $current"
      else
        echo "Current run: idle"
      fi
    fi
    ;;

  init)
    # Re-run the install wizard
    if [[ -f "$VAULT/install/wizard/serve.py" ]]; then
      echo "Opening SpielOS setup wizard at http://localhost:7331"
      exec python3 "$VAULT/install/wizard/serve.py" --port 7331 --target "$VAULT"
    else
      echo "ERROR: install/wizard/serve.py not found in $VAULT" >&2
      exit 1
    fi
    ;;

  sync)
    # Regenerate IDE adapter files
    if [[ -f "$VAULT/tools/sync_adapters.py" ]]; then
      shift
      exec python3 "$VAULT/tools/sync_adapters.py" "$@"
    else
      echo "ERROR: tools/sync_adapters.py not found" >&2
      exit 1
    fi
    ;;

  update)
    # Pre-flight: validate $VAULT is NOT a leaked temp directory.
    # If it is, re-resolve from scratch using cwd + shim path.
    case "$VAULT" in
      /tmp/*|/private/var/folders/*)
        echo ""
        echo "  ⚠ VAULT resolved to temp directory: $VAULT"
        echo "  → Re-resolving from shim location..."
        VAULT_DIR=""
        # Walk up from cwd first (most reliable when cwd is inside a vault)
        d="$PWD"
        while [[ "$d" != "/" ]]; do
          if [[ -d "$d/team" && -f "$d/team/director.md" ]]; then
            VAULT="$d"
            break
          fi
          d=$(dirname "$d")
        done
        # Fall back to shim location
        if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/director.md" ]]; then
          sd=$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd 2>/dev/null || true)
          if [[ -n "$sd" && -f "$sd/../team/director.md" ]]; then
            VAULT=$(cd "$sd/.." && pwd)
          fi
        fi
        if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/director.md" ]]; then
          echo "  ✗ Cannot recover — no valid vault found. Run installer again." >&2
          exit 1
        fi
        echo "  → Re-resolved to: $VAULT"
        echo ""
        ;;
    esac

    # ── Detect local source repo ──
    SOURCE_DIR=""
    if [[ -f "$SPIELOS_GLOBAL_CONFIG" ]]; then
      SOURCE_DIR=$(grep -E '^SOURCE_DIR=' "$SPIELOS_GLOBAL_CONFIG" 2>/dev/null | head -1 | cut -d= -f2- || true)
      SOURCE_DIR="${SOURCE_DIR%\"}"; SOURCE_DIR="${SOURCE_DIR#\"}"
      SOURCE_DIR="${SOURCE_DIR%\'}"; SOURCE_DIR="${SOURCE_DIR#\'}"
    fi

    echo ""
    echo "  Updating SpielOS vault at $VAULT"
    echo "  (preserves: team/, skills/, strategy/, content/, archive/, .env, system/brand.*)"
    echo ""

    if [[ -n "$SOURCE_DIR" && -f "$SOURCE_DIR/tools/sync_adapters.py" && -f "$SOURCE_DIR/team/director.md" ]]; then
      # Local source repo overlay — fast, has local changes
      echo "  → Source: $SOURCE_DIR (local repo)"
      (cd "$VAULT" && python3 - "$SOURCE_DIR" "$VAULT" <<'PYEOF'
import os, shutil, hashlib, sys
src, dst = sys.argv[1], sys.argv[2]
skip_dirs = set("team skills strategy content archive".split())
skip_files = set([".env", "system/brand.md", "system/brand.json"])
updated, added, skipped = [], [], 0
for root, dirs, files in os.walk(src):
    rel = os.path.relpath(root, src)
    parts = rel.split(os.sep) if rel != "." else []
    if any(p in skip_dirs for p in parts): continue
    for f in files:
        rf = os.path.relpath(os.path.join(root, f), src)
        if rf in skip_files: continue
        sp, dp = os.path.join(root, f), os.path.join(dst, rf)
        def h(p):
            try:
                import hashlib as _h
                with open(p, 'rb') as _f: return _h.sha256(_f.read()).hexdigest()
            except OSError: return None
        nh, oh = h(sp), h(dp)
        if nh == oh: skipped += 1; continue
        os.makedirs(os.path.dirname(dp), exist_ok=True)
        shutil.copy2(sp, dp)
        (added if oh is None else updated).append(rf)
print(f"  {len(updated)} updated, {len(added)} added, {skipped} unchanged")
PYEOF
      )
    elif [[ -d "$VAULT/.git" ]] && command -v git >/dev/null 2>&1; then
      echo "  → git pull origin main --ff-only"
      local pull_output
      if pull_output=$(cd "$VAULT" && git pull origin main --ff-only 2>&1); then
        if echo "$pull_output" | grep -q "Already up to date"; then
          echo "  Already up to date."
        else
          echo "  Pulled changes:"
          echo "$pull_output" | sed 's/^/    /'
          echo ""
          echo "  Files changed since last update:"
          cd "$VAULT" && git diff --stat HEAD@{1} HEAD 2>/dev/null | sed 's/^/    /' || true
        fi
        echo "  ✓ tool sources updated"
      else
        echo "  ⚠ git pull failed; falling back to tarball overlay"
        _update_via_tarball
      fi
    else
      echo "  → tarball overlay"
      _update_via_tarball
    fi

    # Rewrite vault pointer files — _rewrite_vault_pointers validates the path
    # and refuses to write if VAULT looks like a temp dir or is not a real vault.
    _rewrite_vault_pointers

    echo ""
    echo "  → sync_adapters --install (push to all IDEs)"
    VAULT_ROOT="$VAULT" python3 "$VAULT/tools/sync_adapters.py" --install 2>&1 | sed 's/^/    /'
    echo ""
    echo "  ─────────────────────────────────────────"
    echo "  ✓ Update complete. Vault: $VAULT"
    echo "    To re-run setup wizard:  spiel init"
    echo ""
    ;;

  set-vault)
    if [[ -z "${2:-}" ]]; then
      echo "ERROR: usage: spiel set-vault <path>" >&2
      exit 1
    fi
    target=$(cd "$2" 2>/dev/null && pwd) || { echo "ERROR: cannot access $2" >&2; exit 1; }
    if [[ ! -d "$target/team" || ! -f "$target/team/director.md" ]]; then
      echo "ERROR: $target is not a SpielOS vault (no team/director.md)" >&2
      exit 1
    fi
    # Write global config to point to the new vault
    mkdir -p "$HOME/.config/spielos"
    printf 'VAULT_DIR=%s\n' "$target" > "$HOME/.config/spielos/config"
    # Write .spiel-vault in the new vault
    printf 'VAULT_DIR=%s\n' "$target" > "$target/.spiel-vault"
    # Re-copy shim from new vault if it has one
    if [[ -f "$target/bin/spiel" ]]; then
      mkdir -p "$(dirname "$SHIM_PATH")"
      cp "$target/bin/spiel" "$SHIM_PATH"
      chmod 0755 "$SHIM_PATH"
    fi
      echo "  ✓ Vault set to $target"
      echo "  → Run 'spiel update' to sync tools + IDEs"
      ;;

  set-source)
    if [[ -z "${2:-}" ]]; then
      echo "ERROR: usage: spiel set-source <path-to-source-repo>" >&2
      exit 1
    fi
    src_path=$(cd "$2" 2>/dev/null && pwd) || { echo "ERROR: cannot access $2" >&2; exit 1; }
    if [[ ! -f "$src_path/tools/sync_adapters.py" ]]; then
      echo "ERROR: $src_path is not a SpielOS source repo (no tools/sync_adapters.py)" >&2
      exit 1
    fi
    mkdir -p "$HOME/.config/spielos"
    if grep -q '^SOURCE_DIR=' "$HOME/.config/spielos/config" 2>/dev/null; then
      sed -i '' "s|^SOURCE_DIR=.*|SOURCE_DIR=$src_path|" "$HOME/.config/spielos/config"
    else
      printf 'SOURCE_DIR=%s\n' "$src_path" >> "$HOME/.config/spielos/config"
    fi
    echo "  ✓ Source repo set to $src_path"
    echo "  → Run 'spiel update' to sync"
    ;;

  test)
    if command -v pytest >/dev/null 2>&1; then
      exec pytest "$VAULT/tests/" -v
    else
      echo "pytest not installed; running minimal smoke tests..."
      exec python3 "$VAULT/tests/smoke.py"
    fi
    ;;

  config)
    echo "vault:    $VAULT"
    echo "editor:   $VAULT/tools/editor.py"
    echo "publisher:$VAULT/tools/publisher/"
    echo "sync:     $VAULT/tools/sync_adapters.py"
    echo "current:  $VAULT/content/current.md"
    echo "inbox:    $VAULT/content/inbox/"
    echo "drafts:   $VAULT/content/drafts/"
    echo "ready:    $VAULT/content/ready/"
    echo "posted:   $VAULT/content/posted/"
    echo "rejected: $VAULT/content/rejected/"
    ;;

  /post)
    echo ""
    echo "  /post is a subagent command, not a CLI command."
    echo ""
    echo "  Invoke it from your IDE: open opencode, Claude Code, Cursor, or any"
    echo "  MCP-compatible agent, then type:"
    echo ""
    echo "      /post \"Just shipped v2\"   (topic or announcement)"
    echo "      /post @file:./notes.md    (from a file)"
    echo ""
    echo "  The Director subagent (team/director.md) runs the lean team."
    echo ""
    echo "  For setup: run \`spiel init\` to open the install wizard."
    echo ""
    ;;

  content)
    # Fallback for IDEs that can't invoke subagents. The slash command file
    # (team/post.md) documents: "fall back to bash: spiel content run <args>".
    # The bash CLI cannot run the LLM-driven pipeline by itself, so we
    # dispatch the same way /post does (with a clear message).
    shift  # consume "content"
    case "${1:-}" in
      run)
        shift  # consume "run"
        echo ""
        echo "  spiel content run <args> is the bash fallback for /post."
        echo ""
        echo "  The /post pipeline is LLM-driven and runs inside your IDE's"
        echo "  subagent runtime. The CLI shim cannot run it standalone."
        echo ""
        echo "  Open opencode, Claude Code, Cursor, or any MCP agent and type:"
        echo ""
        echo "      /post                       (session mode)"
        echo "      /post Just shipped v2       (topic mode)"
        echo "      /post @file:./notes.md      (topic mode from a file)"
        echo ""
        if [[ -n "$*" ]]; then
          echo "  Args received: $*"
          echo "  (Pass them to /post in your IDE to run the pipeline.)"
        fi
        echo ""
        ;;
      *)
        echo "Unknown content subcommand: ${1:-}" >&2
        echo "Usage: spiel content run <args>" >&2
        exit 1
        ;;
    esac
    ;;

  "")
    # Default: print status
    "$0" status
    ;;

  *)
    # Forward unknown commands to the appropriate tool
    case "$1" in
      check|gates)
        if [[ -f "$VAULT/tools/editor.py" ]]; then
          shift
          exec python3 "$VAULT/tools/editor.py" check "$@"
        fi
        ;;
      render|banner)
        if [[ -f "$VAULT/tools/designer.py" ]]; then
          shift
          exec python3 "$VAULT/tools/designer.py" "$@"
        fi
        ;;
      publish|dispatch)
        if [[ -f "$VAULT/tools/publisher/buffer.py" ]]; then
          shift
          exec python3 "$VAULT/tools/publisher/buffer.py" "$@"
        fi
        ;;
    esac

    echo "Unknown command: $1" >&2
    echo "Run \`spiel --help\` for usage." >&2
    exit 1
    ;;
esac
