#!/usr/bin/env bash
# bin/spiel — Single entrypoint for SpielOS.
#
# Resolves the vault root, then execs the requested command.
# Works from ANY working directory, in ANY project, in ANY IDE.
#
# VAULT_DIR resolution order (first match wins):
#   0. $VAULT_DIR                  (env override — most explicit)
#   1. ~/.config/spielos/config     (global config set by installer — primary)
#   2. <cwd>/.spiel-vault          (project-local override file; may set VAULT_DIR=…)
#   3. <cwd>/team/strategist.md      (any parent with the vault marker)
#   4. <this-shim>/..              (only when this shim lives at <vault>/bin/spiel)
#
# Usage (from anywhere):
#   spiel --version
#   spiel --where
#   spiel /post
#   spiel /post "Just shipped v2"
#   spiel /post @file:./notes.md
#   spiel status
#   spiel status --json
#
# Install (idempotent, safe to re-run):
#   install -m 0755 bin/spiel ~/.local/bin/spiel
#
# This file is identical wherever it lives. Keep both copies in sync.

set -euo pipefail

VERSION="1.0.0"
SHIM_PATH="$HOME/.local/bin/spiel"

# ── Help / version (no vault needed) ──────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'USAGE'
spiel — SpielOS orchestrator shim.

USAGE:
  spiel [--version] [--help] [--where] <command> [args...]

COMMANDS:
  /post [topic|@file:]
                         Start a deterministic content run
  post [topic|@file:]    Same as /post
  /post --mode session --transcript-file <path>
                         Start from a captured session transcript
  status                 Show current pipeline state
  status --json          Same, JSON output
  set-vault <path>       Change which vault spiel resolves to (writes global config)
  init                   Re-run the install wizard (rewrites .env, strategy, brand)
  update                 Pull latest tools/install + sync to IDEs
                         (preserves strategy/, content/, .env, brand.*, rules.yaml)
  sync                   Regenerate IDE adapter files
  mcp                    Install MCP server configs to all IDEs (reads .env)
  doctor                 Check runtime, vault, and Codex plugin install health
  guard                  Check for pipeline bypasses and untracked drafts
  clean                  Move untracked drafts/ready to rejected/ (use after guard fail)
  next                   Show the next valid pipeline role/action
  continue               Show how to continue the active run (via next --continue)
  reset                  Clear active run state and handoff; keeps drafts/content
  hook-log               Show recent Codex hook activity
  codex-hook             Internal: Codex UserPromptSubmit hook entrypoint
  test                   Run the test suite
  config                 Print resolved vault + tool paths
  help                   Show this help

VAULT_DIR is resolved (first match wins):
   0. $VAULT_DIR env var                 (per-command override)
   1. ~/.config/spielos/config           (primary — set by installer / spiel set-vault)
   2. walk up from cwd for .spiel-vault  (a file containing VAULT_DIR=/abs/path)
   3. walk up from cwd for team/strategist.md (any parent with the vault marker)
   4. <shim>/..                          (when shim is bundled at <vault>/bin/spiel)

The vault is the directory you install into (your project root).
The shim is path-independent: invoke it from anywhere inside the vault.
USAGE
  exit 0
fi

# ── Vault resolution ─────────────────────────────────────────────────

SPIELOS_GLOBAL_CONFIG="$HOME/.config/spielos/config"

_atomic_write_file() {
  local target="$1"
  local tmp
  tmp="$(mktemp "${target}.tmp.XXXXXX")" || return 1
  cat > "$tmp"
  mv "$tmp" "$target"
}

_write_global_config() {
  local vault_dir="$1"
  local source_dir="${2:-}"
  mkdir -p "$HOME/.config/spielos"
  if [[ -z "$source_dir" && -f "$SPIELOS_GLOBAL_CONFIG" ]]; then
    source_dir=$(grep -E '^SOURCE_DIR=' "$SPIELOS_GLOBAL_CONFIG" 2>/dev/null | head -1 | cut -d= -f2- || true)
    source_dir="${source_dir%\"}"; source_dir="${source_dir#\"}"
    source_dir="${source_dir%\'}"; source_dir="${source_dir#\'}"
  fi
  {
    printf 'VAULT_DIR=%s\n' "$vault_dir"
    [[ -n "$source_dir" ]] && printf 'SOURCE_DIR=%s\n' "$source_dir"
  } | _atomic_write_file "$SPIELOS_GLOBAL_CONFIG"
}

_write_vault_pointer() {
  local vault_dir="$1"
  printf 'VAULT_DIR=%s\n' "$vault_dir" | _atomic_write_file "$vault_dir/.spiel-vault"
}

_set_env_var_file() {
  local file="$1"
  local key="$2"
  local value="$3"
  local tmp
  tmp="$(mktemp "${file}.tmp.XXXXXX")" || return 1
  if [[ -f "$file" ]] && grep -q "^${key}=" "$file" 2>/dev/null; then
    awk -v k="$key" -v v="$value" 'BEGIN{p=k "=" v} $0 ~ "^" k "=" {$0=p} {print}' "$file" > "$tmp"
  elif [[ -f "$file" ]]; then
    cat "$file" > "$tmp"
    printf '\n%s=%s\n' "$key" "$value" >> "$tmp"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp"
  fi
  mv "$tmp" "$file"
}

# A candidate is only accepted if it points to a directory that contains
# team/strategist.md. Each option below is tried in order; an invalid env var,
# stale symlink, or missing path falls through to the next option.
_resolve_vault() {
  local candidate=""

  # 0. $VAULT_DIR env var — per-command override (e.g. VAULT_DIR=/path spiel post)
  if [[ -z "$candidate" && -n "${VAULT_DIR:-}" ]]; then
    if [[ -d "${VAULT_DIR}/team" && -f "${VAULT_DIR}/team/strategist.md" ]]; then
      candidate="${VAULT_DIR}"
    fi
  fi

  # 1. Global config (~/.config/spielos/config) — primary, set by installer / spiel set-vault
  if [[ -z "$candidate" && -f "$SPIELOS_GLOBAL_CONFIG" ]]; then
    local override
    override=$(grep -E '^VAULT_DIR=' "$SPIELOS_GLOBAL_CONFIG" 2>/dev/null | head -1 | cut -d= -f2- || true)
    override="${override%\"}"; override="${override#\"}"
    override="${override%\'}"; override="${override#\'}"
    if [[ -n "$override" && -d "$override/team" && -f "$override/team/strategist.md" ]]; then
      candidate="$override"
    fi
  fi

  # 2. Walk up from cwd for .spiel-vault
  if [[ -z "$candidate" ]]; then
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
      if [[ -f "$dir/.spiel-vault" ]]; then
        local override
        override=$(grep -E '^VAULT_DIR=' "$dir/.spiel-vault" 2>/dev/null | head -1 | cut -d= -f2- || true)
        override="${override%\"}"; override="${override#\"}"
        override="${override%\'}"; override="${override#\'}"
        if [[ -n "$override" && -d "$override/team" && -f "$override/team/strategist.md" ]]; then
          candidate="$override"
          break
        fi
      fi
      dir=$(dirname "$dir")
    done
  fi

  # 3. Walk up from cwd for team/strategist.md
  if [[ -z "$candidate" ]]; then
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
      if [[ -d "$dir/team" && -f "$dir/team/strategist.md" ]]; then
        candidate="$dir"
        break
      fi
      dir=$(dirname "$dir")
    done
  fi

  # 4. Shim bundled in vault (this file is at <vault>/bin/spiel).
  if [[ -z "$candidate" ]]; then
    local shim_path="${BASH_SOURCE[0]:-$0}"
    # If shim is a symlink, follow it.
    if [[ -L "$shim_path" ]]; then
      local shim_target
      shim_target=$(readlink "$shim_path" 2>/dev/null || true)
      if [[ -n "$shim_target" ]]; then
        local shim_dir
        shim_dir=$(cd "$(dirname "$shim_path")" && pwd)
        local resolved
        if [[ "$shim_target" = /* ]]; then
          resolved="$shim_target"
        else
          resolved="$shim_dir/$shim_target"
        fi
        shim_path="$resolved"
      fi
    fi
    local shim_dir
    shim_dir=$(cd "$(dirname "$shim_path")" && pwd)
    if [[ "$shim_dir" == */bin ]] && [[ -f "$shim_dir/../team/strategist.md" ]]; then
      candidate=$(cd "$shim_dir/.." && pwd)
    fi
  fi

  # Validate
  if [[ -z "$candidate" || ! -d "$candidate/team" || ! -f "$candidate/team/strategist.md" ]]; then
    echo "ERROR: spiel could not locate the SpielOS vault." >&2
    echo "" >&2
    echo "  Tried (in order):" >&2
    echo "    0. \$VAULT_DIR env var:           ${VAULT_DIR:-<unset>}" >&2
    echo "    1. ~/.config/spielos/config:     $SPIELOS_GLOBAL_CONFIG" >&2
    local _sv=""
    local d="$PWD"
    while [[ "$d" != "/" ]]; do
      if [[ -f "$d/.spiel-vault" ]]; then _sv="$d/.spiel-vault"; break; fi
      d=$(dirname "$d")
    done
    if [[ -n "$_sv" ]]; then
      echo "    2. <walk up> .spiel-vault:         $_sv" >&2
    else
      echo "    2. <walk up> .spiel-vault:         <not found>" >&2
    fi
    local _tm=""
    d="$PWD"
    while [[ "$d" != "/" ]]; do
      if [[ -f "$d/team/strategist.md" ]]; then _tm="$d/team/strategist.md"; break; fi
      d=$(dirname "$d")
    done
    if [[ -n "$_tm" ]]; then
      echo "    3. <walk up> team/strategist.md:     $_tm (invalid)" >&2
    else
      echo "    3. <walk up> team/strategist.md:     <not found>" >&2
    fi
    local sd
    sd=$(cd "$(dirname "$0")" && pwd)
    if [[ -f "$sd/../team/strategist.md" ]]; then
      echo "    4. <shim>/..:                    $sd/.." >&2
    else
      echo "    4. <shim>/..:                    $sd/.. (not a bundle)" >&2
    fi
    echo "" >&2
    echo "  Fix: re-run the installer:" >&2
    echo "    curl -fsSL https://raw.githubusercontent.com/ShayanSpiel/SpielOS/main/install/install.sh | bash" >&2
    return 1
  fi

  (cd "$candidate" && pwd)
}

VAULT=$(_resolve_vault) || exit 1

# ── Tarball overlay (fallback for `update` when git pull fails) ────────

# Directories and files that update must NEVER overwrite (user data).
# Only personal-level files are protected. Project-level files (team/,
# system/playbook, tools/, install/, etc.) are always updated.
#
# PERSONAL:    strategy/  (audience/offer/voice/examples - filled by wizard)
#              content/    (user drafts, sessions, ready, posted, rejected)
#              .env        (credentials)
#              system/brand.md, system/brand.json  (brand tokens)
#              system/rules.yaml  (mechanical gate config - user may tune)
#
# PROJECT:     team/       (role prompts - canonical, updated on every update)
#              system/*    (playbook - pipeline, run-state, draft-schema, etc.)
#              tools/      (deterministic tools)
#              install/    (installer)
#              bin/        (shim)
#              templates/  (post output shapes)
#              tests/      (test suite)
#              adapters/   (auto-regenerated on sync)
#              archive/    (reference - canonical, updated on every update)
#              skills/     (auto-generated)
#              assets/     (icons, dormant banners)
#              AGENTS.md, README.md, package.json
_SPielos_SKIP_DIRS="strategy content"
_SPielos_SKIP_FILES=".env system/brand.md system/brand.json system/rules.yaml"

_update_via_tarball() {
  SPIELOS_REPO="${SPIELOS_REPO:-ShayanSpiel/SpielOS}"
  local tarball="${TARBALL_URL:-https://github.com/$SPIELOS_REPO/archive/refs/heads/main.tar.gz}"
  local tmpdir
  tmpdir=$(mktemp -d) || { echo "  ⚠ mktemp failed" >&2; return 1; }

  _spiel_cleanup_tmp() { rm -rf "$tmpdir"; }
  trap _spiel_cleanup_tmp EXIT

  if ! curl -fsSL "$tarball" | tar -xz -C "$tmpdir" --strip-components=1 2>/dev/null; then
    echo "  ⚠ tarball download failed" >&2
    return 1
  fi

  # Overlay files from $tmpdir onto $VAULT, skipping user data dirs/files.
  # Reports each changed file individually.
  (cd "$VAULT" && python3 - <<PYEOF
import os, shutil, hashlib

def file_hash(path):
    h = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                h.update(chunk)
        return h.hexdigest()
    except OSError:
        return None

src = "$tmpdir"
dst = "$VAULT"
skip_dirs  = set("${_SPielos_SKIP_DIRS}".split())
skip_files = set("${_SPielos_SKIP_FILES}".split())
updated = []
added = []
skipped = 0

for root, dirs, files in os.walk(src):
    rel = os.path.relpath(root, src)
    parts = rel.split(os.sep) if rel != "." else []
    if any(p in skip_dirs for p in parts):
        continue
    for f in files:
        rel_file = os.path.relpath(os.path.join(root, f), src)
        if rel_file in skip_files:
            continue
        sp = os.path.join(root, f)
        dp = os.path.join(dst, rel_file)
        # Same file (src == dst, or symlink to itself) — skip cleanly
        try:
            if os.path.samefile(sp, dp):
                skipped += 1
                continue
        except OSError:
            pass
        new_hash = file_hash(sp)
        old_hash = file_hash(dp)
        if new_hash == old_hash:
            skipped += 1
            continue
        os.makedirs(os.path.dirname(dp), exist_ok=True)
        shutil.copy2(sp, dp)
        if old_hash is None:
            added.append(rel_file)
        else:
            updated.append(rel_file)

if updated:
    print(f"  Updated ({len(updated)}):")
    for f in sorted(updated):
        print(f"    ~ {f}")
if added:
    print(f"  Added ({len(added)}):")
    for f in sorted(added):
        print(f"    + {f}")
if not updated and not added:
    print("  Already up to date.")
else:
    print(f"\n  {len(updated)} updated, {len(added)} added, {skipped} unchanged (user data preserved)")
PYEOF
)

  trap - EXIT
  rm -rf "$tmpdir"
}

# ── Rewrite vault pointer files (always, on update / install) ────────

_rewrite_vault_pointers() {
  # Safety: never write a temp-directory path to persistent config.
  # A tempdir leak would make spiel unresolvable on next invocation.
  case "$VAULT" in
    /tmp/*|/private/var/folders/*)
      echo "  ⚠ VAULT ($VAULT) looks like a temp directory — refusing to write" >&2
      return 1
      ;;
  esac
  if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/strategist.md" ]]; then
    echo "  ⚠ VAULT ($VAULT) is not a valid vault (no team/strategist.md) - refusing to write" >&2
    return 1
  fi

  _write_vault_pointer "$VAULT"
  _write_global_config "$VAULT"

  # Re-copy shim so next invocation uses the latest vault resolution logic
  if [[ -f "$VAULT/bin/spiel" ]]; then
    mkdir -p "$(dirname "$SHIM_PATH")"
    cp "$VAULT/bin/spiel" "$SHIM_PATH"
    chmod 0755 "$SHIM_PATH"
  fi

  if [[ -f "$VAULT/.env" ]]; then
    _set_env_var_file "$VAULT/.env" "VAULT_DIR" "$VAULT"
    echo "  ✓ VAULT_DIR → $VAULT (global config + .env + .spiel-vault + shim)"
  else
    echo "  ✓ VAULT_DIR → $VAULT (global config + .spiel-vault + shim)"
  fi
}

# ── Version / where (vault already resolved) ─────────────────────────

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  echo "spiel $VERSION"
  echo "vault: $VAULT"
  exit 0
fi

if [[ "${1:-}" == "--where" ]]; then
  echo "$VAULT"
  exit 0
fi

# ── Dispatch ─────────────────────────────────────────────────────────

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is not on PATH. Install Python 3 and retry." >&2
  exit 127
fi

export VAULT_DIR="$VAULT"
cd "$VAULT"

# /post starts the deterministic runtime. IDE/plugin surfaces should call this
# instead of reimplementing the pipeline in prompt instructions.

case "${1:-}" in
  status)
    # Read the state machine (content/.state.json) and the handoff (content/current.md)
    state_file="$VAULT/content/.state.json"
    current_file="$VAULT/content/current.md"
    if [[ "${2:-}" == "--json" ]]; then
      if [[ -f "$state_file" ]]; then
        cat "$state_file"
      else
        echo '{"status": "idle", "step": "idle", "run_id": null, "drafts": [], "ready": [], "error": null}'
      fi
    else
      echo "SpielOS vault: $VAULT"
      if [[ -f "$state_file" ]]; then
        # Pretty-print the key fields from .state.json
        run_id=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(d.get('run_id','?'))" 2>/dev/null || echo "?")
        step=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(d.get('step','?'))" 2>/dev/null || echo "?")
        run_status=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(d.get('status','?'))" 2>/dev/null || echo "?")
        mode=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(d.get('mode','?'))" 2>/dev/null || echo "?")
        drafts=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(len(d.get('drafts',[])))" 2>/dev/null || echo "?")
        ready=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(len(d.get('ready',[])))" 2>/dev/null || echo "?")
        err=$(python3 -c "import json,sys; d=json.load(open('$state_file')); e=d.get('error'); print(e if e else '-')" 2>/dev/null || echo "-")
        updated=$(python3 -c "import json,sys; d=json.load(open('$state_file')); print(d.get('updated_at','?'))" 2>/dev/null || echo "?")
        echo "  run_id:     $run_id"
        echo "  status:     $run_status"
        echo "  step:       $step"
        echo "  mode:       $mode"
        echo "  drafts:     $drafts"
        echo "  ready:      $ready"
        if [[ "$err" != "-" && "$err" != "None" ]]; then
          echo "  error:      $err"
        fi
        echo "  updated_at: $updated"
      else
        echo "  no active run (idle)"
      fi
      if [[ -f "$current_file" ]]; then
        echo "  handoff:    $current_file"
      fi
    fi
    ;;

  /post|post)
    shift
    if [[ -f "$VAULT/tools/post.py" ]]; then
      exec python3 "$VAULT/tools/post.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/post.py not found" >&2
      exit 1
    fi
    ;;

  init)
    # Re-run the install wizard
    if [[ -f "$VAULT/install/wizard/serve.py" ]]; then
      echo "Opening SpielOS setup wizard at http://localhost:7331"
      exec python3 "$VAULT/install/wizard/serve.py" --port 7331 --target "$VAULT"
    else
      echo "ERROR: install/wizard/serve.py not found in $VAULT" >&2
      exit 1
    fi
    ;;

  sync)
    # Regenerate IDE adapter files
    if [[ -f "$VAULT/tools/sync_adapters.py" ]]; then
      shift
      exec python3 "$VAULT/tools/sync_adapters.py" "$@"
    else
      echo "ERROR: tools/sync_adapters.py not found" >&2
      exit 1
    fi
    ;;

  mcp)
    # Install MCP server configs to all IDEs
    if [[ -f "$VAULT/tools/sync_adapters.py" ]]; then
      exec python3 "$VAULT/tools/sync_adapters.py" --mcp
    else
      echo "ERROR: tools/sync_adapters.py not found" >&2
      exit 1
    fi
    ;;

  update)
    # Pre-flight: validate $VAULT is NOT a leaked temp directory.
    # If it is, re-resolve from scratch using cwd + shim path.
    case "$VAULT" in
      /tmp/*|/private/var/folders/*)
        echo ""
        echo "  ⚠ VAULT resolved to temp directory: $VAULT"
        echo "  → Re-resolving from shim location..."
        VAULT_DIR=""
        # Walk up from cwd first (most reliable when cwd is inside a vault)
        d="$PWD"
        while [[ "$d" != "/" ]]; do
          if [[ -d "$d/team" && -f "$d/team/strategist.md" ]]; then
            VAULT="$d"
            break
          fi
          d=$(dirname "$d")
        done
        # Fall back to shim location
        if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/strategist.md" ]]; then
          sd=$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd 2>/dev/null || true)
          if [[ -n "$sd" && -f "$sd/../team/strategist.md" ]]; then
            VAULT=$(cd "$sd/.." && pwd)
          fi
        fi
        if [[ ! -d "$VAULT/team" || ! -f "$VAULT/team/strategist.md" ]]; then
          echo "  ✗ Cannot recover — no valid vault found. Run installer again." >&2
          exit 1
        fi
        echo "  → Re-resolved to: $VAULT"
        echo ""
        ;;
    esac

    # ── Detect local source repo ──
    SOURCE_DIR=""
    if [[ -f "$SPIELOS_GLOBAL_CONFIG" ]]; then
      SOURCE_DIR=$(grep -E '^SOURCE_DIR=' "$SPIELOS_GLOBAL_CONFIG" 2>/dev/null | head -1 | cut -d= -f2- || true)
      SOURCE_DIR="${SOURCE_DIR%\"}"; SOURCE_DIR="${SOURCE_DIR#\"}"
      SOURCE_DIR="${SOURCE_DIR%\'}"; SOURCE_DIR="${SOURCE_DIR#\'}"
    fi

    echo ""
    echo "  Updating SpielOS vault at $VAULT"
    echo "  (preserves ONLY personal data: strategy/, content/, .env, system/brand.*, system/rules.yaml)"
    echo "  (refreshes project files: team/, system/playbook, tools/, install/, bin/, tests/, archive/, skills/, docs)"
    echo ""

    if [[ -n "$SOURCE_DIR" && -f "$SOURCE_DIR/tools/sync_adapters.py" && -f "$SOURCE_DIR/team/strategist.md" ]]; then
      # Local source repo overlay — fast, has local changes
      echo "  → Source: $SOURCE_DIR (local repo)"
      (cd "$VAULT" && python3 - "$SOURCE_DIR" "$VAULT" <<'PYEOF'
import os, shutil, hashlib, sys
src, dst = sys.argv[1], sys.argv[2]
# ONLY personal data is skipped. Role prompts, system playbook, tools, etc. are project-level and always updated.
skip_dirs  = set("strategy content".split())
skip_files = set([".env", "system/brand.md", "system/brand.json", "system/rules.yaml"])
def file_hash(path):
    h = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(8192), b""):
                h.update(chunk)
        return h.hexdigest()
    except OSError:
        return None
updated, added, skipped = [], [], 0
for root, dirs, files in os.walk(src):
    rel = os.path.relpath(root, src)
    parts = rel.split(os.sep) if rel != "." else []
    if any(p in skip_dirs for p in parts):
        continue
    for f in files:
        rf = os.path.relpath(os.path.join(root, f), src)
        if rf in skip_files:
            continue
        sp, dp = os.path.join(root, f), os.path.join(dst, rf)
        # Same file (src == dst, or symlink to itself) — skip cleanly
        try:
            if os.path.samefile(sp, dp):
                continue
        except OSError:
            pass
        nh, oh = file_hash(sp), file_hash(dp)
        if nh == oh:
            skipped += 1
            continue
        os.makedirs(os.path.dirname(dp), exist_ok=True)
        shutil.copy2(sp, dp)
        (added if oh is None else updated).append(rf)
if updated:
    print(f"  Updated ({len(updated)}):")
    for f in sorted(updated):
        print(f"    ~ {f}")
if added:
    print(f"  Added ({len(added)}):")
    for f in sorted(added):
        print(f"    + {f}")
if updated or added:
    print(f"\n  {len(updated)} updated, {len(added)} added, {skipped} unchanged (personal data preserved)")
else:
    print("  Already up to date.")
PYEOF
      )
    elif [[ -d "$VAULT/.git" ]] && command -v git >/dev/null 2>&1; then
      echo "  → git pull origin main --ff-only"
      if pull_output=$(cd "$VAULT" && git pull origin main --ff-only 2>&1); then
        if echo "$pull_output" | grep -q "Already up to date"; then
          echo "  Already up to date."
        else
          echo "  Pulled changes:"
          echo "$pull_output" | sed 's/^/    /'
          echo ""
          echo "  Files changed since last update:"
          cd "$VAULT" && git diff --stat HEAD@{1} HEAD 2>/dev/null | sed 's/^/    /' || true
        fi
        echo "  ✓ tool sources updated"
      else
        echo "  ⚠ git pull failed; falling back to tarball overlay"
        _update_via_tarball
      fi
    else
      echo "  → tarball overlay"
      _update_via_tarball
    fi

    # Rewrite vault pointer files — _rewrite_vault_pointers validates the path
    # and refuses to write if VAULT looks like a temp dir or is not a real vault.
    _rewrite_vault_pointers

    echo ""
    echo "  → sync_adapters --install (push to all IDEs)"
    VAULT_ROOT="$VAULT" python3 "$VAULT/tools/sync_adapters.py" --install 2>&1 | sed 's/^/    /'
    echo ""
    echo "  ─────────────────────────────────────────"
    echo "  ✓ Update complete. Vault: $VAULT"
    echo "    To re-run setup wizard:  spiel init"
    echo ""
    ;;

  set-vault)
    if [[ -z "${2:-}" ]]; then
      echo "ERROR: usage: spiel set-vault <path>" >&2
      exit 1
    fi
    target=$(cd "$2" 2>/dev/null && pwd) || { echo "ERROR: cannot access $2" >&2; exit 1; }
    if [[ ! -d "$target/team" || ! -f "$target/team/strategist.md" ]]; then
      echo "ERROR: $target is not a SpielOS vault (no team/strategist.md)" >&2
      exit 1
    fi
    _write_global_config "$target"
    _write_vault_pointer "$target"
    # Update VAULT_DIR in .env (add if missing)
    if [[ -f "$target/.env" ]]; then
      _set_env_var_file "$target/.env" "VAULT_DIR" "$target"
    fi
    # Re-copy shim from new vault if it has one
    if [[ -f "$target/bin/spiel" ]]; then
      mkdir -p "$(dirname "$SHIM_PATH")"
      cp "$target/bin/spiel" "$SHIM_PATH"
      chmod 0755 "$SHIM_PATH"
    fi
      # Update the current shell's env var so the effect is immediate.
      # This makes spiel set-vault work even when $VAULT_DIR is set in
      # the parent environment, without requiring unset or a new shell.
      export VAULT_DIR="$target"
      echo "  ✓ Vault set to $target"
      echo "    (global config + current shell updated)"
      echo ""
      echo "  → Run 'spiel update' to sync tools + IDEs"
      ;;

  set-source)
    if [[ -z "${2:-}" ]]; then
      echo "ERROR: usage: spiel set-source <path-to-source-repo>" >&2
      exit 1
    fi
    src_path=$(cd "$2" 2>/dev/null && pwd) || { echo "ERROR: cannot access $2" >&2; exit 1; }
    if [[ ! -f "$src_path/tools/sync_adapters.py" ]]; then
      echo "ERROR: $src_path is not a SpielOS source repo (no tools/sync_adapters.py)" >&2
      exit 1
    fi
    _write_global_config "$VAULT" "$src_path"
    echo "  ✓ Source repo set to $src_path"
    echo "  → Run 'spiel update' to sync"
    ;;

  test)
    if command -v pytest >/dev/null 2>&1; then
      exec pytest "$VAULT/tests/" -v
    else
      echo "pytest not installed; running minimal smoke tests..."
      exec python3 "$VAULT/tests/smoke.py"
    fi
    ;;

  config)
    echo "vault:    $VAULT"
    echo "editor:   $VAULT/tools/editor.py"
    echo "publisher:$VAULT/tools/publisher/"
    echo "sync:     $VAULT/tools/sync_adapters.py"
    echo "current:  $VAULT/content/current.md"
    echo "inbox:    $VAULT/content/inbox/"
    echo "drafts:   $VAULT/content/drafts/"
    echo "ready:    $VAULT/content/ready/"
    echo "posted:   $VAULT/content/posted/"
    echo "rejected: $VAULT/content/rejected/"
    ;;

  doctor)
    shift
    if [[ -f "$VAULT/tools/doctor.py" ]]; then
      exec python3 "$VAULT/tools/doctor.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/doctor.py not found" >&2
      exit 1
    fi
    ;;

  guard)
    shift
    if [[ -f "$VAULT/tools/guard.py" ]]; then
      exec python3 "$VAULT/tools/guard.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/guard.py not found" >&2
      exit 1
    fi
    ;;

  clean)
    shift
    if [[ -f "$VAULT/tools/guard.py" ]]; then
      exec python3 "$VAULT/tools/guard.py" --clean "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/guard.py not found" >&2
      exit 1
    fi
    ;;

  next)
    shift
    if [[ -f "$VAULT/tools/next.py" ]]; then
      exec python3 "$VAULT/tools/next.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/next.py not found" >&2
      exit 1
    fi
    ;;

  continue)
    shift
    if [[ -f "$VAULT/tools/next.py" ]]; then
      exec python3 "$VAULT/tools/next.py" --continue "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/next.py not found" >&2
      exit 1
    fi
    ;;

  reset)
    shift
    if [[ -f "$VAULT/tools/advance.py" ]]; then
      exec python3 "$VAULT/tools/advance.py" --reset "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/advance.py not found" >&2
      exit 1
    fi
    ;;

  hook-log|hooklog|hooks-log)
    shift
    if [[ -f "$VAULT/tools/hook_log.py" ]]; then
      exec python3 "$VAULT/tools/hook_log.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/hook_log.py not found" >&2
      exit 1
    fi
    ;;

  codex-hook)
    shift
    if [[ -f "$VAULT/tools/codex_hook.py" ]]; then
      exec python3 "$VAULT/tools/codex_hook.py" "$@" --vault "$VAULT"
    else
      echo "ERROR: tools/codex_hook.py not found" >&2
      exit 1
    fi
    ;;

  content)
    # Fallback for IDEs that can't invoke subagents. The slash command file
    # (team/post.md) documents: "fall back to bash: spiel content run <args>".
    # The bash CLI cannot run the LLM-driven pipeline by itself, so we
    # dispatch the same way /post does (with a clear message).
    shift  # consume "content"
    case "${1:-}" in
      run)
        shift  # consume "run"
        exec "$0" post "$@"
        ;;
      *)
        echo "Unknown content subcommand: ${1:-}" >&2
        echo "Usage: spiel content run <args>" >&2
        exit 1
        ;;
    esac
    ;;

  "")
    # Default: print status
    "$0" status
    ;;

  *)
    # Forward unknown commands to the appropriate tool
    case "$1" in
      check|gates)
        if [[ -f "$VAULT/tools/editor.py" ]]; then
          shift
          exec python3 "$VAULT/tools/editor.py" check "$@"
        fi
        ;;
      render|banner)
        if [[ -f "$VAULT/tools/designer.py" ]]; then
          shift
          exec python3 "$VAULT/tools/designer.py" "$@"
        fi
        ;;
      publish|dispatch)
        if [[ -f "$VAULT/tools/publisher/buffer.py" ]]; then
          shift
          exec python3 "$VAULT/tools/publisher/buffer.py" "$@"
        fi
        ;;
    esac

    echo "Unknown command: $1" >&2
    echo "Run \`spiel --help\` for usage." >&2
    exit 1
    ;;
esac
