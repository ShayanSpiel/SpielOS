#!/usr/bin/env bash
# Pre-commit hook for the Spiel Engine
set -euo pipefail

VAULT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "═══ Pre-commit: Spiel Engine ═══"

# 1. Check .wiki-state is valid
if [[ -f "$VAULT_DIR/.wiki-state" ]]; then
    python3 -c "
import yaml
with open('$VAULT_DIR/.wiki-state') as f:
    data = yaml.safe_load(f)
state = data.get('current_state', 'UNKNOWN')
if state != 'IDLE':
    print(f'ERROR: System is in {state}, not IDLE. Run: engine.py wiki reset')
    exit(1)
print(f'  .wiki-state: IDLE ✓')
" 2>&1 || exit 1
fi

# 2. Check new/modified .md files have frontmatter
echo "  Checking frontmatter..."
git diff --cached --name-only --diff-filter=ACM | grep '\.md$' | while read -r f; do
    filepath="$VAULT_DIR/$f"
    [[ ! -f "$filepath" ]] && continue
    # Skip archive, content, raw, node_modules
    [[ "$f" == _archive/* ]] && continue
    [[ "$f" == content/* ]] && continue
    [[ "$f" == raw/* ]] && continue
    [[ "$f" == node_modules/* ]] && continue
    head -1 "$filepath" | grep -q '^---$' || {
        echo "  WARN: $f has no frontmatter"
        exit 1
    }
done

echo "═══ Pre-commit passed ═══"
