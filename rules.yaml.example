# rules.yaml — Engine Configuration
# Copy this to rules.yaml and edit. Or run the setup prompt in SETUP.md.
# This file is gitignored once copied; the .example stays versioned.

state:
  wiki_loop: IDLE
  content_loop: IDLE

posting:
  mode: manual                             # manual | auto-threshold | auto-always
  quality_threshold: 0.85
  max_auto_day: 3
  require_confirm: [blog, linkedin]

platforms:
  x:
    max_chars: 280
    max_lines: 8
    max_hashtags: 2
  linkedin:
    max_chars: 3000
    min_chars: 100
    max_hashtags: 5
  blog:
    min_chars: 600
    max_chars: 3000

gates:
  max_word_repeat: 3
  max_generic_statements: 1
  max_architectural_references: 1
  banner_dir: assets/banners/
  screenshot_dir: assets/screenshots/
  char_min: 40
  char_max: 3000

strategy:
  verticals: []
  archetypes: {}
  icp: {}
  offer: {}
  funnel: {}
  matrix: {}
