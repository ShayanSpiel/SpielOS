#!/usr/bin/env bash
# scripts/bin/spiel — Single entrypoint for the Spiel Engine.
#
# Resolves the vault root, then execs scripts/engine.py inside it.
# Works from ANY working directory, in ANY project, in ANY IDE.
#
# VAULT_DIR resolution order (first match wins):
#   1. $VAULT_DIR                  (inline env override)
#   2. <cwd>/.spiel-vault          (project-local override file; may set VAULT_DIR=…)
#   3. ~/.config/opencode/.env     (the global source of truth)
#   4. <this-shim>/../..           (only when this shim lives at <vault>/scripts/bin/spiel)
#
# Usage (from anywhere):
#   spiel status
#   spiel wiki extract
#   spiel content run
#   spiel queue
#   spiel log --tail 20
#   spiel --version
#   spiel --help
#
# Install (idempotent, safe to re-run):
#   install -m 0755 scripts/bin/spiel ~/.local/bin/spiel
#
# This file is identical wherever it lives. Keep both copies in sync.

set -euo pipefail

VERSION="1.0.0"

# ── Help / version (no vault needed) ──────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'USAGE'
spiel — single entrypoint for the Spiel Engine

USAGE:
  spiel [--version] [--help] [--where] <engine-subcommand> [args...]

ARGS:
  --version, -v    print version + resolved vault path, then exit
  --where          print the resolved vault path, then exit
  --help, -h       print this help, then exit
  <subcommand>     any subcommand accepted by scripts/engine.py
                   (status, wiki ..., content ..., queue, recover, log, ...)

VAULT_DIR is resolved (first match wins):
  1. $VAULT_DIR env var
  2. <cwd>/.spiel-vault        (a file containing VAULT_DIR=/abs/path)
  3. ~/.config/opencode/.env   (the global source of truth)
  4. <shim>/../..              (when shim is bundled at <vault>/scripts/bin/spiel)

The shim is path-independent: invoke it from any project, any IDE, any shell.
USAGE
  exit 0
fi

# ── Vault resolution ─────────────────────────────────────────────────

_resolve_vault() {
  local candidate=""

  # 1. Inline env var
  if [[ -n "${VAULT_DIR:-}" ]]; then
    candidate="$VAULT_DIR"
  fi

  # 2. Project-local override
  if [[ -z "$candidate" && -f "$PWD/.spiel-vault" ]]; then
    candidate=$(grep -E '^VAULT_DIR=' "$PWD/.spiel-vault" 2>/dev/null | head -1 | cut -d= -f2- || true)
  fi

  # 3. Global user-level .env (the source of truth)
  if [[ -z "$candidate" && -f "$HOME/.config/opencode/.env" ]]; then
    candidate=$(grep -E '^VAULT_DIR=' "$HOME/.config/opencode/.env" 2>/dev/null | head -1 | cut -d= -f2- || true)
  fi

  # 4. Shim bundled in vault at scripts/bin/spiel
  if [[ -z "$candidate" ]]; then
    local shim_dir
    shim_dir=$(cd "$(dirname "$0")" && pwd)
    if [[ "$shim_dir" == */scripts/bin ]]; then
      candidate=$(cd "$shim_dir/../.." && pwd)
    fi
  fi

  # Strip surrounding quotes / whitespace
  candidate="${candidate%\"}"; candidate="${candidate#\"}"
  candidate="${candidate%\'}"; candidate="${candidate#\'}"
  candidate="${candidate## }";  candidate="${candidate%% }"

  # Validate: must be a directory that contains scripts/engine.py
  if [[ -z "$candidate" || ! -d "$candidate/scripts" || ! -f "$candidate/scripts/engine.py" ]]; then
    echo "ERROR: spiel could not locate the Spiel Engine vault." >&2
    echo "" >&2
    echo "  Tried (in order):" >&2
    echo "    1. \$VAULT_DIR env var:           ${VAULT_DIR:-<unset>}" >&2
    if [[ -f "$PWD/.spiel-vault" ]]; then
      echo "    2. <cwd>/.spiel-vault:           $(cat "$PWD/.spiel-vault" 2>/dev/null | head -3)" >&2
    else
      echo "    2. <cwd>/.spiel-vault:           <not found>" >&2
    fi
    if [[ -f "$HOME/.config/opencode/.env" ]]; then
      echo "    3. ~/.config/opencode/.env:      $(grep -E '^VAULT_DIR=' "$HOME/.config/opencode/.env" | head -1)" >&2
    else
      echo "    3. ~/.config/opencode/.env:      <not found>" >&2
    fi
    shim_dir=$(cd "$(dirname "$0")" && pwd)
    echo "    4. <shim>/../..:                 $shim_dir/../..  (not a scripts/bin shim)" >&2
    echo "" >&2
    echo "  Fix (pick one):" >&2
    echo "    a) Set VAULT_DIR in ~/.config/opencode/.env:" >&2
    echo "         echo 'VAULT_DIR=/abs/path/to/vault' >> ~/.config/opencode/.env" >&2
    echo "    b) Run the engine's SETUP.md (installs the shim + writes .env automatically)." >&2
    echo "    c) Drop a .spiel-vault file in your project root with: VAULT_DIR=/abs/path" >&2
    echo "" >&2
    return 1
  fi

  # Normalize to absolute
  (cd "$candidate" && pwd)
}

VAULT=$(_resolve_vault) || exit 1

# ── Version / where (vault already resolved) ──────────────────────────

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  echo "spiel $VERSION"
  echo "vault: $VAULT"
  exit 0
fi

if [[ "${1:-}" == "--where" ]]; then
  echo "$VAULT"
  exit 0
fi

# ── Run engine.py inside the vault ────────────────────────────────────

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is not on PATH. Install Python 3 and retry." >&2
  exit 127
fi

export VAULT_DIR="$VAULT"
cd "$VAULT"
exec python3 "$VAULT/scripts/engine.py" "$@"
