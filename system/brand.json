            "qrcode",
            "qr code",
            "decode",
            "extract",
            "extracting"
          ],
          "icon": "qrcode"
        }
      ]
    },
    "templates": {
      "default": {
        "_comment": "Canonical default template. Lives at tools/banner-templates/default.html. Tokens defined in banner.tokens (no per-template overrides needed)."
      },
      "notes": {
        "_comment": "Sticky-note themed template for short personal notes. Lives at tools/banner-templates/notes.html. Inherits global tokens; override here if you ever fork its look."
      }
    }
  },
  "icons": {
    "registry": {
      "arrow-up-right": {
        "svg_path": "icons/arrow-up-right.svg"
